rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: username, email, phone, avatar, settings, created_at
    //
    // Collection: events
    // Fields: user_id, type, amount, category, description, date, account_name, target_account, is_interest, created_at
    //
    // Collection: goals
    // Fields: user_id, name, target_amount, current_amount, emoji, color, deadline, account_name, completed_at, created_at
    //
    // Collection: subscriptions
    // Fields: isPremium, stripeCustomerId, subscriptionId, premiumUntil, updatedAt
    //
    // Collection: reminders
    // Fields: user_id, account_name, type, day_of_month, advance_days, created_at
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.user_id;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "erickortizmy@gmail.com" && request.auth.token.email_verified == true));
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['username']) &&
             data.username is string && data.username.size() > 0 && data.username.size() < 100;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['user_id', 'type', 'amount', 'date']) &&
             data.user_id == request.auth.uid &&
             data.type in ['income', 'expense', 'transfer'] &&
             data.amount is number &&
             data.date is string;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['user_id', 'name', 'target_amount']) &&
             data.user_id == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.target_amount is number;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['user_id', 'account_name', 'type', 'date']) &&
             data.user_id == request.auth.uid &&
             data.account_name is string && data.account_name.size() > 0 &&
             data.type in ['payment_due', 'cutoff'] &&
             data.date is string && data.date.size() >= 10;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());

      match /aiChats/{month} {
        allow read, write: if isOwner(userId);
      }
    }

    match /events/{eventId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidEvent(request.resource.data);
      allow update: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && isValidEvent(request.resource.data);
      allow delete: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidGoal(request.resource.data);
      allow update: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && isValidGoal(request.resource.data);
      allow delete: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReminder(request.resource.data);
      allow update: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && isValidReminder(request.resource.data);
      allow delete: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid || isAdmin());
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only admin (server) should write to subscriptions
      allow write: if isAdmin();
    }
  }
}
